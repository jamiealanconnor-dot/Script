local function GetCounts(str)
    local counts = {}

    for word in string.gmatch(str, "[^|]+") do
        counts[word] = (counts[word] or 0) + 1
    end

    return counts
end

local function SameCombination(wanted, actual)
    local countWanted = GetCounts(wanted)
    local countActual = GetCounts(actual)

    for enchant, amount in pairs(countWanted) do
        if (countActual[enchant] or 0) < amount then
            return false
        end
    end

    print("found: "..wanted)
    return true
end

