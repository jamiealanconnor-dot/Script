}

local function FindValue(Type, WantedValue)
    local Module = Modules[Type]
    if not Module then
        warn(Type .. " is not a valid module type")
        return nil
    end
    for index, data in pairs(Module) do
        if data.Name == WantedValue then
            return index
        end
    end
    return nil
end

local function Darken(color, amount)
    return Color3.new(
        math.clamp(color.R - amount, 0, 1),
        math.clamp(color.G - amount, 0, 1),
        math.clamp(color.B - amount, 0, 1)
    )
end

