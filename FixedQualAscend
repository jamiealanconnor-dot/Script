local function ReadAscendNotification(rawText)
	local cleanText = CleanRichText(rawText)
	local rng = cleanText:match("%((.-)%)")
	if rng then
		local number, suffix = rng:match("1/([%d,%.]+)(%a*)")

		if number then
			local cleanedNumber = number:gsub(",", "")
			number = tonumber(cleanedNumber)

			if number then

				-- Keep decimal precision for suffix values like M/B/T
				if suffix and suffix ~= "" then
					rng = string.format("1/%.2f%s", number, suffix)

				-- Normal comma formatting for regular numbers
				else
					rng = "1/" .. AddCommas(math.floor(number + 0.5))
				end
			end
		end
	end

	local value, upgradeType

	local patterns = {
		{ pattern = "You have ascended your sword to%s+([%w%s%+%-]+)%s+Rarity", type = "Rarity" },
		{ pattern = "You have ascended your sword to%s+([%w%s%+%-]+)%s+Quality", type = "Quality" },
		{ pattern = "You have ascended your sword to%s+([%w%s%+%-]+)%s+Mold", type = "Mold" },

		{ pattern = "You have gotten an%s+([%w%s%+%-]+)%s+Rarity", type = "Rarity" },
		{ pattern = "You have gotten an%s+([%w%s%+%-]+)%s+Quality", type = "Quality" },
		{ pattern = "You have gotten an%s+([%w%s%+%-]+)%s+Mold", type = "Mold" },
	}

	for _, data in ipairs(patterns) do
		value = cleanText:match(data.pattern)

		if value then
			upgradeType = data.type
			break
		end
	end

	if value and upgradeType and rng then
	table.insert(AscendNotificationQueue[upgradeType], {
		Type = upgradeType,
		Value = value,
		RNG = rng,
		Time = tick()
	})

		print("Stored notification ascend:", upgradeType, value, rng)
	else
		warn("Failed to parse ascend notification:", cleanText)
	end
end

