local function GetEnchantTierNumber(value)
	if not value then
		return nil
	end

	value = tostring(value):lower()

	local color, symbol = value:match("<font color=[\"'](#[%da-f]+)[\"']>(%+%+)</font>")

	if not color then
		color, symbol = value:match("<font color=[\"'](#[%da-f]+)[\"']>(%+)</font>")
	end

	if not color then
		color, symbol = value:match("<font color=[\"'](#[%da-f]+)[\"']>(%-)</font>")
	end

	if not color or not symbol then
		return nil
	end

	local key = "<font color='" .. color .. "'>" .. symbol .. "</font>"
	return EnchantTiers[key]
end

local function IsEnchantAtOrAboveTarget(value)
	local valueNumber = GetEnchantTierNumber(value)
	local targetNumber = GetEnchantTierNumber(TranscendTarget)

	return valueNumber and targetNumber and valueNumber >= targetNumber
end

local function SwordNeedsTranscending(sword)
	local info = GetSwordInfo(sword)
	if not info then
		return false
	end

	local targetNumber = GetEnchantTierNumber(TranscendTarget)
	if not targetNumber then
		return false
	end

	for _, enchantName in ipairs({"Enchant1", "Enchant2", "Enchant3"}) do
		local value = GetEnchantValueFromInfo(info, enchantName)
		local valueNumber = GetEnchantTierNumber(value)

		if not valueNumber then
			return true
		end

		if valueNumber < targetNumber then
			return true
		end
	end

	return false
end

