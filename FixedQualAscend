local function GetEnchantTierRichText(shortText)
	shortText = tostring(shortText)

	local symbol, tier = shortText:match("^(%+%+)(%d+)$")

	if not symbol then
		symbol, tier = shortText:match("^(%+)(%d+)$")
	end

	if not symbol then
		symbol, tier = shortText:match("^(%-)(%d+)$")
	end

	if not symbol or not tier then
		return nil
	end

	tier = tonumber(tier)

	local color = EnchantTierColors[tier]
	if not color then
		return nil
	end

	return "<font color='" .. color .. "'>" .. symbol .. "</font>"
end

