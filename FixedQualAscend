local function GetMatches(input, options, limit)
	local matches = {}

	if not input or input == "" or not options then
		return matches
	end

	input = input:lower()

	for _, name in ipairs(options) do
		if name:lower():sub(1, #input) == input then
			table.insert(matches, name)
		end
	end

	return matches
end

local function GetNamesFromModule(module)
	local names = {}

	for _, data in pairs(module) do
		if data.Name then
			table.insert(names, data.Name)
		end
	end

	table.sort(names, function(a, b)
		return a:lower() < b:lower()
	end)

	return names
end

