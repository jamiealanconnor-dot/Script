local function RunTranscender()
	if not AscendTranscend then
		return false
	end

	local sword = GetCurrentTranscenderSword()

	if not sword then
		local swords = GetTranscendBankSwordsThatNeedAscending()

		if #swords == 0 then
			return false
		end

		local inserted = WithMovementLock(function()
			return InsertSwordIntoTranscender(swords[1])
		end)

		if not inserted then
			return false
		end

		repeat
		task.wait(0.1)
		sword = GetCurrentTranscenderSword()
		until sword
	end

	for _, enchant in ipairs({"Enchant1", "Enchant2", "Enchant3"}) do
		TranscendEnchant(enchant)
	end

	WithMovementLock(function()
		BankTranscenderSword()
	end)

	return true
end

