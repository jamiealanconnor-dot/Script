	button.TextColor3 = Color3.fromRGB(255,255,255)
	button.Font = Enum.Font.SourceSansBold
	button.TextSize = 15*UIScale
	button.Parent = frame

	local value = defaultValue
	local lastExtraText = ""

	local function refresh(extraText)
	if extraText ~= nil then
		lastExtraText = extraText
	end

	button.Text =
		labelText .. ": " ..
		(value and "ON" or "OFF") ..
		lastExtraText

	button.BackgroundColor3 =
		value and Color3.fromRGB(0,120,0)
		or Color3.fromRGB(120,0,0)
	end

	ToggleButtons[labelText] = {
		Button = button,
		GetValue = function()
			return value
		end,
		Refresh = refresh
	}

	button.MouseButton1Click:Connect(function()
		value = not value
		callback(value)
		refresh()
	end)

	refresh()
	return button
end

