	local swordObj = GetSwordObject(sword.Name)
	if not swordObj or not swordObj:FindFirstChild("Main") then
		return false
	end

	RemoteEvent:FireServer("Set Transcender Mode", enchantName)

	repeat
		task.wait(0.1)

		swordObj = GetSwordObject(sword.Name)
		if not swordObj or not swordObj:FindFirstChild("Main") then
			return false
		end

	until (TranscendIndex[GetEnchantValueFromInfo(swordObj.Main.Gui.ItemInfo, enchantName)] or 0) >= TranscendTargetNumber

	task.wait(2.25)
	RemoteEvent:FireServer("Set Transcender Mode", "")
	task.wait(2.25)

	return true
end

local function GetWeatherNames()
	local rawText = Players.LocalPlayer.PlayerGui.Main.Level.WeatherLuck.Text
	local weatherNames = {}

	for weatherName in rawText:gmatch(">([^<>%[]+)%s*%[x[%d%.]+%]</font>") do
		weatherName = weatherName:gsub("^%s+", ""):gsub("%s+$", "")

		if weatherName ~= "" then
			table.insert(weatherNames, weatherName)
		end
	end

	if #weatherNames == 0 then
		return "None"
	end

	return table.concat(weatherNames, ", ")
end

