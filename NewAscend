local function UpdateUI(Rar, Qual, Mol, Clas, Ench, Lev)

	local Counts = {
		Rarity = Rar,
		Quality = Qual,
		Mold = Mol,
		Class = Clas
	}

	local modes = {}

	for _, mode in ipairs(Order) do

		if mode == "Rarity" and AscendRarity then
			table.insert(
				modes,
				"Rarity: "..RarityTarget.." ["..Counts.Rarity.."]"
			)

		elseif mode == "Quality" and AscendQuality then
			table.insert(
				modes,
				"Quality: "..QualityTarget.." ["..Counts.Quality.."]"
			)

		elseif mode == "Mold" and AscendMold then
			table.insert(
				modes,
				"Mold: "..MoldTarget.." ["..Counts.Mold.."]"
			)

		elseif mode == "Class" and AscendClass then
			table.insert(
				modes,
				"Class: "..ClassTarget.." ["..Counts.Class.."]"
			)

		elseif mode == "Enchant" and AscendEnchant then
			table.insert(
				modes,
				"Enchanting: ".._G.EnchantTime.."s ["..Ench.."]"
			)

		elseif mode == "Level" and AscendLevel then
			table.insert(
				modes,
				"Leveling: ".._G.LevelTime.."s ["..Lev.."]"
			)
		end
	end

	local modeText

	if #modes == 0 then
		modeText = "No Modes"
	else
		modeText = table.concat(modes, "\n")
	end

	button.Text =
		(enabled and "Ascend: Enabled\n" or "Ascend: Disabled\n")
		.. modeText

	button.BackgroundColor3 =
		enabled and Color3.fromRGB(0,170,0)
		or Color3.fromRGB(170,0,0)
end

