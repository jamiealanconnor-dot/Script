local function WaitForAscendData(upgradeType, wantedValue, timeout)
	local startWait = tick()

	repeat
		local queue = AscendNotificationQueue[upgradeType]

		for i = #queue, 1, -1 do
			local data = queue[i]

			if data.Value == wantedValue then
				table.remove(queue, i)
				return data
			end
		end

		task.wait(0.1)
	until tick() - startWait >= timeout

	return nil
end

