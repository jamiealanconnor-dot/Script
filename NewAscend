local function GetEnchantValueFromInfo(info, enchantName)
	local enchants = info:FindFirstChild("Enchants")
	if not enchants then
		return nil
	end

	local label = enchants:FindFirstChild(enchantName)
	if not label then
		return nil
	end

	return label.Text:match("([+-]%d*)")
end

local function SwordNeedsTranscending(sword)
	if not TranscendTargetNumber then
		return false
	end

	local info = GetSwordInfo(sword)
	if not info then
		return false
	end

	for _, enchantName in ipairs({"Enchant1", "Enchant2", "Enchant3"}) do
		local value = GetEnchantValueFromInfo(info, enchantName)
		local valueNumber = TranscendIndex[value]

		if not valueNumber or valueNumber < TranscendTargetNumber then
			return true
		end
	end

	return false
end

local function GetTranscendBankSwordsThatNeedAscending()
	local swords = {}

	for _, sword in ipairs(PlrStats.Bank:GetChildren()) do
		if SwordNeedsTranscending(sword) then
			table.insert(swords, sword)
		end
	end

	return swords
end

local function TranscendEnchant(enchantName)
	local sword = GetCurrentTranscenderSword()
