local function SortSwordsByValue(swords, getValue)
	table.sort(swords, function(a, b)
		local aValue = getValue(a) or 0
		local bValue = getValue(b) or 0

		if SwordAscendingOrder == "Highest" then
			return aValue > bValue
		end

		return aValue < bValue
	end)

	return swords
end

local function GetRarityBankSwordsThatNeedAscending()
	local swords = {}
	for _, sword in ipairs(PlrStats.Bank:GetChildren()) do
		local swordObj = GetSwordObject(sword.Name)
		if swordObj then
            if swordObj:FindFirstChild("Main") then
			local rarityText = swordObj.Main.Gui.ItemInfo.RarityQuality.Text
			local rarity = getSwordRarityFromText(rarityText)
			if rarity and rarity < RarityTargetNumber then
				table.insert(swords, sword)
			end
            end
		end
	end
	return SortSwordsByValue(swords, function(sword)
	local swordObj = GetSwordObject(sword.Name)
	if swordObj and swordObj:FindFirstChild("Main") then
		return getSwordRarityFromText(swordObj.Main.Gui.ItemInfo.RarityQuality.Text)
	end
end)
end

