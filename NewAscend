local function SortSwordsByValue(swords, getValue)
	table.sort(swords, function(a, b)
		local aValue = getValue(a) or 0
		local bValue = getValue(b) or 0

		if SwordAscendingOrder == "Highest" then
			return aValue > bValue
		end

		return aValue < bValue
	end)

	return swords
end

local function GetSwordInfo(sword)
	local swordObj = GetSwordObject(sword.Name)

	if not swordObj or not swordObj:FindFirstChild("Main") then
		return nil
	end

	return swordObj.Main.Gui.ItemInfo
end

local function GetBankSwordsThatNeedAscending(targetNumber, getValue)
	local swords = {}

	if not targetNumber then
		return swords
	end

	for _, sword in ipairs(PlrStats.Bank:GetChildren()) do
		local value = getValue(sword)

		if value and value < targetNumber then
			table.insert(swords, sword)
		end
	end

	return SortSwordsByValue(swords, getValue)
end

local function GetRarityBankSwordsThatNeedAscending()
