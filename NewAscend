local function CleanRichText(text)
	return text:gsub("<.->", "")
end

local function AddCommas(n)
	local left, num, right = tostring(n):match('^([^%d]*%d)(%d*)(.-)$')
	return left .. (num:reverse():gsub('(%d%d%d)', '%1,'):reverse()) .. right
end
