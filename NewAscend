local function GetWeatherNames()
	local rawText = Players.LocalPlayer.PlayerGui.Main.Level.WeatherLuck.Text
	local weatherNames = {}

	for weatherName in rawText:gmatch(">([^<>%[]+)%s*%[x[%d%.]+%]</font>") do
		weatherName = weatherName:gsub("^%s+", ""):gsub("%s+$", "")

		if weatherName ~= "" then
			table.insert(weatherNames, weatherName)
		end
	end

	if #weatherNames == 0 then
		return "None"
	end

	return table.concat(weatherNames, ", ")
end

--Sword Helper
local function InsertSword(targetSword)
	if #PlrStats.Ascender:GetChildren() ~= 0 then
		return true
	end
	local swordObj = GetSwordObject(targetSword.Name)

	if not swordObj then
		return false
	end
	repeat
		plr.Character.HumanoidRootPart.CFrame =
			swordObj.Main.CFrame + Vector3.new(0, 6, 0)
		task.wait(LagPreventionTimeToPickupSwords)
	until PlrStats.Swords:FindFirstChild(targetSword.Name)
	TP("Ascender")
	DropSword(targetSword.Name)
	return true
end

local function Ascend(mode, duration)
	ChangeAscenderMode(mode)
	local start = tick()
	repeat
		task.wait(0.1)
	until tick() - start >= duration
end

local function WaitForAscendData(upgradeType, timeout)
	local startWait = tick()

	repeat
		local data = LastAscendDataByType[upgradeType]

		if data then
			return data
		end

		task.wait(0.1)
	until tick() - startWait >= timeout

	return nil
end

