local function BankSword()
	local currentSword = GetCurrentSword()
	ChangeAscenderMode(nil, true)
	TP("Bank")
	if currentSword then
		DropSword(currentSword.Name)
	end
end

--Sword Helper
local function InsertSword(targetSword)
	if #PlrStats.Ascender:GetChildren() ~= 0 then
		return true
	end
	local swordObj = GetSwordObject(targetSword.Name)

	if not swordObj then
		return false
	end
	repeat
		plr.Character.HumanoidRootPart.CFrame =
			swordObj.Main.CFrame + Vector3.new(0, 6, 0)
		task.wait(LagPreventionTimeToPickupSwords)
	until PlrStats.Swords:FindFirstChild(targetSword.Name)
	TP("Ascender")
	DropSword(targetSword.Name)
	return true
end

local function Ascend(mode, duration)
	ChangeAscenderMode(mode)
	local start = tick()
	repeat
		task.wait(0.1)
	until tick() - start >= duration
end

local Tasks = {

	Rarity = function()
		if not AscendRarity or not RarityTargetNumber then
			return false
		end
		local swords = GetRarityBankSwordsThatNeedAscending()
		if #swords == 0 then
			return false
		end
		local sword = swords[1]
		InsertSword(sword)
		ChangeAscenderMode("Rarity")
		repeat
			task.wait(0.1)
		until (GetCurrentSwordRarity() or 0) >= RarityTargetNumber
		BankSword()
		return true
	end,

	Quality = function()
		if not AscendQuality or not QualityTargetNumber then
			return false
		end
		local swords = GetQualityBankSwordsThatNeedAscending()
		if #swords == 0 then
			return false
		end
		local sword = swords[1]
		InsertSword(sword)
		ChangeAscenderMode("Quality")
		repeat
			task.wait(0.1)
		until (GetCurrentSwordQuality() or 0) >= QualityTargetNumber
		BankSword()
		return true
	end,

	Mold = function()
		if not AscendMold or not MoldTargetNumber then
			return false
		end
		local swords = GetMoldBankSwordsThatNeedAscending()
		if #swords == 0 then
			return false
		end
		local sword = swords[1]
		InsertSword(sword)
		ChangeAscenderMode("Mold")
		repeat
			task.wait(0.1)
		until (GetCurrentSwordMold() or 0) >= MoldTargetNumber
		BankSword()
		return true
	end,

	Class = function()
		if not AscendClass or not ClassTargetNumber then
			return false
		end
		local swords = GetClassBankSwordsThatNeedAscending()
		if #swords == 0 then
			return false
		end
		local sword = swords[1]
		InsertSword(sword)
		ChangeAscenderMode("Class")
		repeat
			task.wait(0.1)
		until (GetCurrentSwordClass() or 0) >= ClassTargetNumber
		BankSword()
		return true
	end,

    Enchant = function()
	    if not AscendEnchant then
	    	return false
	    end
	    for _, sword in ipairs(PlrStats.Bank:GetChildren()) do
	    	if not CompletedTimedAscends.Enchant[sword.Name] then
	    		CompletedTimedAscends.Enchant[sword.Name] = true
	    		InsertSword(sword)
	    		Ascend("Enchant", _G.EnchantTime)
	      		BankSword()
	    		return true
	    	end
	    end
	    return false
    end,

    Level = function()
	    if not AscendLevel then
	    	return false
	    end
	    for _, sword in ipairs(PlrStats.Bank:GetChildren()) do
	    	if not CompletedTimedAscends.Level[sword.Name] then
	    		CompletedTimedAscends.Level[sword.Name] = true
	    		InsertSword(sword)
	    		Ascend("Level", _G.LevelTime)
	    		BankSword()
	    		return true
	    	end
	    end
	    return false
    end
}

