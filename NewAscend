-- Build reverse rarity lookup
local RarityIndex = {}
for index, data in pairs(RarityModule) do
	RarityIndex[data.Name] = index
end

local QualityIndex = {}
for index, data in pairs(QualityModule) do
	QualityIndex[data.Name] = index
end

local MoldIndex = {}

for index, data in pairs(MoldModule) do
	MoldIndex[data.Name] = index
end

local ClassIndex = {}

for index, data in pairs(ClassModule) do
	ClassIndex[data.Name] = index
end

local RarityTargetNumber = RarityIndex[RarityTarget]
local QualityTargetNumber = QualityIndex[QualityTarget]
local MoldTargetNumber = MoldIndex[MoldTarget]
local ClassTargetNumber = ClassIndex[ClassTarget]

-- Functions
local function getSwordRarityFromText(text)
	local rarityName = text:match("</font>%s*(.+)")
	return RarityIndex[rarityName]
end

local function getSwordQualityFromText(text)
	local qualityName = text:match('">(.-)</font>')
	return QualityIndex[qualityName]
end

local function TP(location)
	RemoteFunction:InvokeServer("Teleport In Base", location)
	task.wait(0.25)
end

local function ChangeAscenderMode(mode, pickup)
	if pickup then
		RemoteFunction:InvokeServer("Pickup Ascender")
		return
	end
	RemoteEvent:FireServer("Set Ascender Mode", mode)
	task.wait(1)
end

local function DropSword(swordId)
	swordId = tostring(swordId)
	RemoteEvent:FireServer("Drop Sword", swordId)
	RemoteEvent:FireServer("Set Hotbar", swordId, "Inventory")
	task.wait(0.5)
end

local function GetSwordObject(swordName)
	return SwordsFolder:FindFirstChild(swordName)
end

local function GetCurrentSword()
	return PlrStats.Ascender:GetChildren()[1]
end

local function GetCurrentSwordRarity()
	local sword = GetCurrentSword()
	if not sword then
		return nil
	end
	local swordObj = GetSwordObject(sword.Name)
	if not swordObj then
		return nil
	end
    if swordObj:FindFirstChild("Main") then
	local info = swordObj.Main.Gui.ItemInfo
	return getSwordRarityFromText(info.RarityQuality.Text)
    else
        return nil
    end
end

